<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#10B981"/>
  <g transform="translate(400, 280)">
    <!-- Android robot icon -->
    <rect x="-50" y="0" width="100" height="80" rx="10" fill="white" opacity="0.9"/>
    <circle cx="-20" cy="30" r="8" fill="#10B981"/>
    <circle cx="20" cy="30" r="8" fill="#10B981"/>
    <rect x="-30" y="55" width="20" height="30" rx="5" fill="white" opacity="0.9"/>
    <rect x="10" y="55" width="20" height="30" rx="5" fill="white" opacity="0.9"/>
    <rect x="-70" y="10" width="15" height="50" rx="7" fill="white" opacity="0.9"/>
    <rect x="55" y="10" width="15" height="50" rx="7" fill="white" opacity="0.9"/>
    <!-- Antennae -->
    <line x1="-25" y1="0" x2="-40" y2="-25" stroke="white" stroke-width="4" stroke-linecap="round" opacity="0.9"/>
    <line x1="25" y1="0" x2="40" y2="-25" stroke="white" stroke-width="4" stroke-linecap="round" opacity="0.9"/>
  </g>
  <text x="400" y="500" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle" opacity="0.8">Android Study App</text>
</svg>