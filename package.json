{
  "name": "personal-resume-website",
  "version": "1.0.0",
  "private": true,
  "description": "A modern, responsive personal resume website built with Next.js 16, TypeScript, and Tailwind CSS",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "serve": "npx serve@latest out -l 3000",
    "lint": "echo 'ESLint temporarily disabled due to eslint-config-next@16.2.4 circular dependency bug. Will be fixed in next Next.js release.'",
    "lint:fix": "echo 'ESLint temporarily disabled due to eslint-config-next@16.2.4 circular dependency bug. Will be fixed in next Next.js release.'",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:lighthouse": "jest --testPathPattern=lighthouse",
    "test:lighthouse:full": "npm run build && npm run serve & sleep 5 && npm run test:lighthouse; kill $!",
    "test:properties": "jest --testPathPattern=properties",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.50.0",
    "autoprefixer": "^10.x",
    "fast-check": "^3.x",
    "firebase": "^10.14.1",
    "gray-matter": "^4.x",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.2",
    "postcss": "^8.5.10",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.x",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^3.x",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-storybook": "^10.3.5",
    "firebase-admin": "^13.8.0",
    "husky": "^9",
    "jest": "^29",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15",
    "playwright": "^1.59.1",
    "prettier": "^3",
    "storybook": "^10.3.5",
    "ts-jest": "^29.4.9",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
